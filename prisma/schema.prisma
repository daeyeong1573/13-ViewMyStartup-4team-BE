generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Category {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now()) @map("created_at")

  startups Startup[]

  @@map("category")
}

model Startup {
  id                  String    @id @default(uuid())
  categoryId          String    @map("category_id")
  name                String
  description         String
  imgUrl              String    @map("img_url")
  totalInvestment     BigInt    @default(0) @map("total_investment")
  revenue             BigInt    @default(0)
  employeeCount       Int       @default(0) @map("employee_count")
  myStartupCount      Int       @default(0) @map("my_startup_count")
  compareStartupCount Int       @default(0) @map("compare_startup_count")
  latestSelectedAt    DateTime? @map("latest_selected_at")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  category           Category            @relation(fields: [categoryId], references: [id])
  virtualInvestments VirtualInvestment[]
  mySelections       CompareSelection[]  @relation("MyStartup")
  compareSelections  CompareSelection[]  @relation("CompareStartup")

  @@map("startup")
}

model VirtualInvestment {
  id           String   @id @default(uuid())
  startupId    String   @map("startup_id")
  investorName String   @map("investor_name")
  amount       BigInt
  comment      String
  passwordHash String   @map("password_hash")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  startup Startup @relation(fields: [startupId], references: [id])

  @@map("virtual_investment")
}

model CompareSelection {
  id               String   @id @default(uuid())
  myStartupId      String   @map("my_startup_id")
  compareStartupId String   @map("compare_startup_id")
  selectedAt       DateTime @default(now()) @map("selected_at")

  myStartup      Startup @relation("MyStartup", fields: [myStartupId], references: [id])
  compareStartup Startup @relation("CompareStartup", fields: [compareStartupId], references: [id])

  @@map("compare_selection")
}
